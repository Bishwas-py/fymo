"""App-owned user storage, sqlite3 from the stdlib.

Generated by `fymo generate auth`. This is your table and your code: the
schema lives in schema/users.sql (also yours), fymo never reads or writes
it. Swap this whole module for Postgres, an ORM, or an external service
whenever you outgrow it; only app/auth/routes.py and app/auth/extras.py
call into it.

The uid the rest of the app sees is str(users.id): fymo treats it as an
opaque string and never parses it.
"""
import sqlite3
from contextlib import closing
from datetime import datetime, timezone
from pathlib import Path

from fymo.auth import hash_password, verify_password as check_password

# data/ next to fymo.yml, the same place the storage: convention uses.
# Edit freely; keep it out of git (data/ or *.db in .gitignore).
_PROJECT_ROOT = Path(__file__).resolve().parents[2]
DB_PATH = _PROJECT_ROOT / "data" / "app.db"
_SCHEMA_PATH = _PROJECT_ROOT / "schema" / "users.sql"

# A real scrypt hash of a throwaway password, computed once on the first
# failed lookup. verify() runs a genuine check against it when the email
# does not exist, so "unknown email" costs the same ~50ms as "wrong
# password" and response timing cannot enumerate registered emails.
_decoy_hash = None

# schema/users.sql is applied once per process (CREATE TABLE IF NOT EXISTS
# makes it idempotent). It never ALTERs an existing table: once the table
# exists, evolve it with your own migrations, not by editing the file alone.
_schema_applied = False


class EmailAlreadyRegistered(Exception):
    """The email collides with an existing users row."""


def _connect() -> sqlite3.Connection:
    global _schema_applied
    DB_PATH.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    if not _schema_applied:
        conn.executescript(_SCHEMA_PATH.read_text())
        conn.commit()
        _schema_applied = True
    return conn


def create(email: str, password: str) -> str:
    """Insert a user and return the new uid. Raises EmailAlreadyRegistered."""
    email = email.strip().lower()
    created_at = datetime.now(timezone.utc).isoformat()
    with closing(_connect()) as conn:
        try:
            with conn:
                cur = conn.execute(
                    "INSERT INTO users (email, password_hash, created_at) VALUES (?, ?, ?)",
                    (email, hash_password(password), created_at),
                )
        except sqlite3.IntegrityError:
            raise EmailAlreadyRegistered(email) from None
        return str(cur.lastrowid)


def get_by_email(email: str):
    """Return the users row (sqlite3.Row) or None."""
    with closing(_connect()) as conn:
        return conn.execute(
            "SELECT * FROM users WHERE email = ?", (email.strip().lower(),)
        ).fetchone()


def get_by_id(uid: str):
    """Return the users row for a resolved uid, or None."""
    with closing(_connect()) as conn:
        return conn.execute("SELECT * FROM users WHERE id = ?", (uid,)).fetchone()


def verify(email: str, password: str):
    """Check credentials; return the uid on success, None on any failure.

    Unknown email and wrong password are indistinguishable to the caller,
    by design: same return value, same (decoy-equalized) timing.
    """
    global _decoy_hash
    row = get_by_email(email)
    if row is None:
        if _decoy_hash is None:
            _decoy_hash = hash_password("decoy-timing-equalizer")
        check_password(password, _decoy_hash)
        return None
    if not check_password(password, row["password_hash"]):
        return None
    return str(row["id"])
