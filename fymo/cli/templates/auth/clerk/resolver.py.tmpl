"""Clerk identity resolver, generated by `fymo generate auth --clerk`.

This file is yours and it owns the vendor dependency: it verifies Clerk
session JWTs (RS256 over JWKS) with PyJWT directly. fymo itself does not
depend on PyJWT, so add

    pyjwt[crypto]>=2.0

to THIS app's dependencies (requirements.txt or pyproject.toml) before
relying on this resolver. The import is lazy, inside the verifier, so the
module loads fine before you do; the first authenticated request fails
loudly with the same instruction instead.

Configuration comes from the environment, never fymo.yml:

    CLERK_ISSUER                      e.g. https://clerk.example.com
    PUBLIC_CLERK_PUBLISHABLE_KEY      pk_test_... / pk_live_...; used to
                                      derive the issuer when CLERK_ISSUER
                                      is not set
"""
import base64
import os

from fymo.auth import Identity, identify

# Clerk's default session cookie; it also accepts Authorization: Bearer.
SESSION_COOKIE = "__session"

_jwks_client = None


def _issuer() -> str:
    issuer = os.environ.get("CLERK_ISSUER")
    if issuer:
        return issuer
    key = os.environ.get("PUBLIC_CLERK_PUBLISHABLE_KEY", "")
    # Clerk publishable keys base64-encode the frontend API domain,
    # terminated with a literal "$": pk_test_Y2xlcmsuZXhhbXBsZS5jb20k
    # decodes to clerk.example.com$.
    parts = key.split("_", 2)
    if len(parts) == 3 and parts[0] == "pk":
        encoded = parts[2]
        padded = encoded + "=" * (-len(encoded) % 4)
        try:
            domain = base64.b64decode(padded).decode("ascii").rstrip("$")
        except Exception:
            domain = ""
        if domain:
            return f"https://{domain}"
    raise RuntimeError(
        "Clerk resolver has no issuer: set CLERK_ISSUER, or "
        "PUBLIC_CLERK_PUBLISHABLE_KEY (the pk_test_/pk_live_ key) so it "
        "can be derived. Edit app/auth/resolver.py to change how this is "
        "configured."
    )


def _verify(token: str):
    """Return the JWT claims, or None for any invalid/expired token."""
    try:
        import jwt
        from jwt import PyJWKClient
    except ImportError as e:
        raise RuntimeError(
            "app/auth/resolver.py verifies Clerk JWTs with PyJWT, which is "
            "not installed. Add pyjwt[crypto]>=2.0 to this app's "
            "dependencies and reinstall."
        ) from e
    global _jwks_client
    issuer = _issuer()
    if _jwks_client is None:
        _jwks_client = PyJWKClient(f"{issuer}/.well-known/jwks.json")
    try:
        signing_key = _jwks_client.get_signing_key_from_jwt(token)
        return jwt.decode(
            token,
            signing_key.key,
            algorithms=["RS256"],
            issuer=issuer,
            # Set an audience and verify_aud=True if your Clerk JWT template
            # includes one.
            options={"verify_aud": False},
        )
    except Exception:
        return None


@identify
def by_clerk(event):
    token = event.cookies.get(SESSION_COOKIE)
    if not token:
        auth = event.headers.get("authorization", "")
        if auth.lower().startswith("bearer "):
            token = auth[7:].strip()
    if not token:
        return None
    claims = _verify(token)
    if not claims:
        return None
    sub = claims.get("sub")
    if not sub:
        return None
    # Namespaced uid ("clerk:user_abc") so a second mechanism added later
    # (api keys, another IdP) can never collide with Clerk subjects. Map
    # sub to your own users table here instead if you keep local rows.
    return Identity(uid=f"clerk:{sub}")
