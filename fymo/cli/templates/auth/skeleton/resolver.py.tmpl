"""Identity resolver skeleton, generated by `fymo generate auth --skeleton`.

Build your own auth on fymo's mechanism:

  * fymo auto-discovers app/auth/*.py; every @identify function registers
    as a resolver. Deleting this directory turns identity resolution off.
  * A resolver receives a fymo.auth.ResolverEvent (.cookies, .headers,
    .remote_addr, .scheme) and returns Identity(uid="...") for a signed-in
    request or None for anonymous.
  * Resolvers chain in registration order; the first non-None Identity
    wins. Add one function per mechanism (session cookie, api key, ...).
  * Read the resolved uid anywhere in a request with
    fymo.auth.current_uid(); guard pages with `require_auth:` in fymo.yml
    and remote functions with @fymo.auth.require_auth.

Useful primitives, all stdlib-only:

    from fymo.auth import sign_token, verify_token          # signed uid tokens
    from fymo.auth import hash_password, verify_password    # scrypt hashes
    from fymo.remote import set_cookie, clear_cookie        # response cookies
"""
from fymo.auth import Identity, identify


@identify
def resolve(event):
    # Replace this with a real lookup. Examples:
    #
    #   session cookie:
    #     token = event.cookies.get("session")
    #     uid = verify_token(token) if token else None
    #     return Identity(uid=uid) if uid else None
    #
    #   api key header:
    #     key = event.headers.get("x-api-key")
    #     uid = my_key_table_lookup(key)
    #     return Identity(uid=f"apikey:{uid}") if uid else None
    #
    # Until then every request is anonymous.
    return None
