"""Tests for app/remote/__fymo_tmpl_name__.py (generated; they are yours).

fymo.testing simulates identities without a server: signed_in() registers
an identity resolver and opens a request scope, which is exactly what
@require_auth checks; acting_as() switches to a second user mid-test to
prove one identity cannot touch another's rows. Anonymous callers need
only a plain request scope. Direct calls, no HTTP.
"""
import pytest

from fymo.remote import NotFound
from fymo.remote.context import request_scope
from fymo.remote.errors import RemoteError
from fymo.testing import acting_as, signed_in

from app.remote.__fymo_tmpl_name__ import (
    create___fymo_tmpl_name_singular__,
    delete___fymo_tmpl_name_singular__,
    get___fymo_tmpl_name_singular__,
    list___fymo_tmpl_name__,
    update___fymo_tmpl_name_singular__,
)


def test_list___fymo_tmpl_name___returns_the_seed_row():
    items = list___fymo_tmpl_name__()
    assert any(item["created_by"] == "seed" for item in items)


def test_get___fymo_tmpl_name_singular___returns_the_seed_row():
    assert get___fymo_tmpl_name_singular__(1)["created_by"] == "seed"


def test_get___fymo_tmpl_name_singular___unknown_id_raises_not_found():
    with pytest.raises(NotFound):
        get___fymo_tmpl_name_singular__(999)


def test_create___fymo_tmpl_name_singular___attributes_the_signed_in_caller():
    with signed_in("u_test1") as ident:
        item = create___fymo_tmpl_name_singular__(title="A new item")
    assert item["title"] == "A new item"
    assert item["created_by"] == ident.uid


def test_create___fymo_tmpl_name_singular___rejects_anonymous_callers():
    with request_scope(uid="u_anon", environ={}):
        with pytest.raises(RemoteError) as excinfo:
            create___fymo_tmpl_name_singular__(title="nope")
    assert excinfo.value.status == 401


def test_update___fymo_tmpl_name_singular___by_the_owner():
    with signed_in("u_test1"):
        item = create___fymo_tmpl_name_singular__(title="Draft")
        updated = update___fymo_tmpl_name_singular__(item["id"], title="Final")
    assert updated["id"] == item["id"]
    assert updated["title"] == "Final"


def test_delete___fymo_tmpl_name_singular___by_the_owner():
    with signed_in("u_test1"):
        item = create___fymo_tmpl_name_singular__(title="Disposable")
        deleted = delete___fymo_tmpl_name_singular__(item["id"])
    assert deleted["id"] == item["id"]
    assert all(row["id"] != item["id"] for row in list___fymo_tmpl_name__())


def test_someone_elses___fymo_tmpl_name_singular___reads_as_missing():
    # NotFound, never Forbidden: a distinguishable 403 would confirm the
    # id exists. The seed row's owner is "seed", so even a signed-in
    # caller cannot touch it.
    with signed_in("u_test1"):
        item = create___fymo_tmpl_name_singular__(title="Mine")
        with pytest.raises(NotFound):
            update___fymo_tmpl_name_singular__(1, title="steal the seed row")
        with acting_as("u_other"):
            with pytest.raises(NotFound):
                update___fymo_tmpl_name_singular__(item["id"], title="steal")
            with pytest.raises(NotFound):
                delete___fymo_tmpl_name_singular__(item["id"])


def test_mutations_reject_anonymous_callers():
    with request_scope(uid="u_anon", environ={}):
        with pytest.raises(RemoteError) as excinfo:
            update___fymo_tmpl_name_singular__(1, title="nope")
        assert excinfo.value.status == 401
        with pytest.raises(RemoteError) as excinfo:
            delete___fymo_tmpl_name_singular__(1)
        assert excinfo.value.status == 401
